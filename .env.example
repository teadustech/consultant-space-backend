# Copy this file to .env and fill in the values.

# Required: MongoDB connection
MONGODB_URI=mongodb://localhost:27017/go-to-experts
# Or: MONGO_URI=mongodb://localhost:27017/go-to-experts

# Required: JWT secret for auth tokens (use a long random string in production)
JWT_SECRET=your-jwt-secret-change-in-production

# Server
PORT=5000
NODE_ENV=development

# Optional: CORS (comma-separated origins in production)
# ALLOWED_ORIGINS=https://yoursite.com,https://www.yoursite.com

# Optional: Razorpay (needed for payments)
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=

# Optional: Email (password reset, etc.)
# EMAIL_USER=
# EMAIL_PASSWORD=
# CLIENT_URL=http://localhost:3000

# Optional: Google Meet integration
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account-credentials.json
